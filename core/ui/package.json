    "@ctrl/tinycolor": "^3.4.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.5.2",
    "@types/react": "^18.2.0",
    "lodash-es": "^4.17.21",
    "react-icons": "^4.12.0"
  },
  "devDependencies": {
    "@storybook/react": "^7.6.3",
    "@villagekit/tsconfig": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.2.2"
  },

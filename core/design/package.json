{
  "name": "@villagekit/design",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./kit": {
      "types": "./dist/kit.d.ts",
      "import": "./dist/kit.mjs",
      "require": "./dist/kit.js",
      "default": "./dist/kit.mjs"
    },
    "./type-bundles/*.d.ts": {
      "import": "./dist-type-bundles/*.d.ts",
      "require": "./dist-type-bundles/*.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build:types": "dts-bundle-generator --config ./dts-bundle-generator.json",
    "build:pkg": "npm run build:types && tsup src --no-splitting",
    "lint": "biome check .",
    "publint": "publint"
  },
  "dependencies": {
    "@villagekit/part-gridbeam": "*",
    "@villagekit/part-gridpanel": "*",
    "@villagekit/product-kit": "*"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.3.1"
  },
  "peerDependencies": {}
}

{
  "name": "@villagekit/design",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    "./kit": {
      "types": "./dist/kit.d.ts",
      "source": "./src/kit.ts",
      "import": "./dist/kit.js",
      "default": "./dist/kit.js"
    },
    "./type-bundles/kit.d.ts": "./dist-type-bundles/kit.d.ts"
  },
  "files": ["./src", "./dist", "./dist-type-bundles"],
  "sideEffects": false,
  "scripts": {
    "build:types": "dts-bundle-generator --config ./dts-bundle-generator.json",
    "build:pkg": "npm run build:types && tsup src --no-splitting",
    "lint": "biome check .",
    "publint": "publint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/villagekit/villagekit.git"
  },
  "author": "Village Kit <dev@villagekit.com>",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/villagekit/villagekit/issues"
  },
  "homepage": "https://github.com/villagekit/villagekit/tree/main/core/design#readme",
  "dependencies": {
    "@villagekit/part-gridbeam": "*",
    "@villagekit/part-gridpanel": "*",
    "@villagekit/product-kit": "*"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1"
  },
  "peerDependencies": {}
}

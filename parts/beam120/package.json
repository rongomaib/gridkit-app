{
  "name": "@villagekit/part-beam120",
  "version": "0.1.0",
  "license": "EUPL-1.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./creator": {
      "types": "./dist/creator.d.ts",
      "source": "./src/creator.ts",
      "import": "./dist/creator.js",
      "default": "./dist/creator.js"
    },
    "./bundles/creator": "./dist-bundles/creator.js",
    "./package.json": "./package.json"
  },
  "files": ["./src", "./dist", "./dist-bundles"],
  "sideEffects": ["./src/index.ts", "./dist/index.js", "./src/creator.ts", "./dist/creator.js"],
  "scripts": {
    "build:dist": "tsup src",
    "build:dist-bundles": "rollup dist/creator.js --file ./dist-bundles/creator.js --format esm",
    "build:pkg": "pnpm run build:dist && pnpm run build:dist-bundles",
    "lint": "biome check ."
  },
  "dependencies": {
    "@villagekit/math": "workspace:*",
    "@villagekit/part": "workspace:*",
    "@villagekit/units": "workspace:*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@react-three/fiber": "^9.0.0",
    "react": "^19.1.0",
    "three": "^0.165.0"
  }
}

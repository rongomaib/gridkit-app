{
  "name": "villagekit",
  "private": true,
  "scripts": {
    "build:pkg": "turbo build:pkg",
    "dev:pkg": "tsx ./watch.ts",
    "//": "--concurrency 1000 until https://github.com/vercel/turbo/pull/6790 fixed",
    "dev:app": "turbo dev:app --concurrency 1000",
    "dev": "pnpm run '/^dev:.*/'",
    "lint": "turbo lint",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.3.3",
    "@villagekit/tsconfig": "workspace:*",
    "patch-package": "^8.0.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "turbo": "^1.11.3",
    "turbotree": "^1.0.1",
    "turbowatch": "^2.29.4"
  },
  "packageManager": "pnpm",
  "pnpm": {
    "patchedDependencies": {
      "turbowatch@2.29.4": "patches/turbowatch@2.29.4.patch"
    }
  }
}

{
  "name": "villagekit",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "build:app": "turbo build:app",
    "build:pkg": "turbo build:pkg",
    "dev:pkg": "turbo watch build:pkg",
    "dev:app": "turbo watch build:pkg dev:app",
    "dev:app:studio": "npm run dev:app -w '@villagekit/studio'",
    "dev:app:storybook": "npm run dev:app -w '@villagekit/storybook'",
    "lint": "turbo lint",
    "format": "biome check --apply .",
    "format:unsafe": "biome check --apply-unsafe .",
    "publint": "turbo publint",
    "test": "turbo test",
    "version": "npm version $npm_package_version --workspaces && biome check --apply $(glob **/package.json) && git add **/package.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.6.3",
    "@optimize-lodash/esbuild-plugin": "^2.0.3",
    "@tauri-apps/cli": "^1.5.9",
    "@types/lodash-es": "^4.17.0",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/three": "^0.150.1",
    "@villagekit/tsconfig": "*",
    "esbuild-plugin-file-path-extensions": "^2.0.0",
    "glob": "^10.3.12",
    "patch-package": "^8.0.0",
    "publint": "^0.2.7",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "turbo": "^2.0.3",
    "vite": "^5.0.0",
    "vite-tsconfig-paths": "^4.3.1"
  },
  "workspaces": [
    "dev/*",
    "core/*",
    "util/*",
    "parts/*",
    "products/*",
    "apps/*"
  ],
  "overrides": {
    "three": "^0.150.1"
  },
  "version": "0.0.2",
  "packageManager": "npm@10.5.0"
}

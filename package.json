{
  "name": "villagekit",
  "private": true,
  "scripts": {
    "build:app": "turbo build:app",
    "build:app:studio": "pnpm --filter '@villagekit/storybook' run build:app",
    "build:pkg": "turbo build:pkg",
    "dev:pkg": "turbo watch build:pkg",
    "dev:app": "turbo watch build:pkg dev:app --filter=!@villagekit/storybook",
    "dev:app:studio": "pnpm --filter '@villagekit/studio' run dev:app",
    "dev:app:storybook": "pnpm --filter '@villagekit/storybook' run dev:app",
    "deps": "turbo deps",
    "types": "turbo types",
    "lint": "turbo lint",
    "format": "biome check --apply .",
    "format:unsafe": "biome check --apply-unsafe .",
    "publint": "turbo publint",
    "test": "turbo test",
    "test:pkg": "turbo build:pkg && turbo types",
    "version": "biome check --apply $(glob **/package.json) && git add **/package.json",
    "version:bump": "lerna version --sync-workspace-lock",
    "release:dry": "lerna publish from-git --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@lerna-lite/cli": "^5.2.1",
    "@lerna-lite/publish": "^5.2.1",
    "@optimize-lodash/esbuild-plugin": "^2.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.168.0",
    "@villagekit/tsconfig": "workspace:*",
    "depcheck": "^1.4.7",
    "dts-bundle-generator": "^9.5.1",
    "esbuild-plugin-file-path-extensions": "^2.1.2",
    "esbuild-plugin-raw": "^0.1.8",
    "glob": "^10.4.1",
    "publint": "^0.2.8",
    "rollup": "^4.21.2",
    "tsup": "^8.1.0",
    "tsx": "^4.15.1",
    "turbo": "^2.0.4",
    "vite": "^5.2.13",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "overrides": {
    "three": "^0.168.0"
  },
  "pnpm": {
    "overrides": {
      "three": "^0.168.0"
    }
  },
  "packageManager": "pnpm@9.9.0"
}

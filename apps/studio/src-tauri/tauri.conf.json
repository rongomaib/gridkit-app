{
  "productName": "studio",
  "version": "0.1.0",
  "identifier": "com.villagekit.studio.app",
  "build": {
    "beforeDevCommand": "pnpm run js:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run js:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "studio",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
